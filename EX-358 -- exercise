9.0 Providing File-based Network Storage

- The root user on servera.lab.example.com can neither read nor write to the share, due to file permissions and the default root_squash setting.

-  /nfsshare directory so that only servera.lab.example.com can mount the shared export in read/write mode. Ensure that all other systems in the lab.example.com DNS domain can only mount the shared export in read-only mode.

/nfsshare servera.lab.example.com(rw) *.lab.example.com(ro)

$ cat /etc/exports
/srv/operator servera.lab.example.com(rw) 
- root_squash (default) that makes root on servera.lab.example.com unable to read or write.

$ dnf install nfs-utils
$ systemctl enable --now nfs-server
$ firewall-cmd --add-service=nfs --permanet
$ mkdir /srv/operators
$ chgrp operators /srv/operators
$ chmod 2770 /srv/operators
$ cat /etc/exports
/srv/operators servera.lab.example.com(rw)
$ systemctl reload nfs-server
$ exportfs

$ cat /etc/fstab
serverd.lab.example.com:/nfsshare /share nfs defaults 0 0

---
- name: NFS
  hosts: export_nfs
  tasks:
    - name: Install nfs
      dnf:
        name: nfs-utils
        state: present

    - name: Start the nfs service
      service:
        name: nfs-server
        state: started
        enabled: true

    - name: Create the directory to share
      ansible.builtin.file:
        path: /srv/operator
        owner: root
        group: operators
        mode: '2770'
        state: directory

    - name: Create export files
      ansible.builtin.copy:
        content: |
          /srv/operator servera.lab.example.com(rw)
        dest: /etc/exports
        owner: root
        group: root
        mode: "0644"
      notify: reload-nfs-server

    - name: open firewall
      ansible.posix.firewalld:
        service: nfs
        state: enabled
        immediate: true
        permanent: true
  
