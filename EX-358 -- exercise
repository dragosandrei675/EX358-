$ dnf install -y samba
$ systemctl start samba
$ firewall-cmd --add-service=smb --permanent
$ mkdir /srv/sambashare
$ useradd -r -s /sbin/nologin sambamount
$ smbpasswd -a sambamount
$ useradd -s /sbin/nologin -G developers developer1
$ smbpasswd -a developer1
$ semanage fcontext -a -t samba_share_t '/srv/sambashare(/.*)?'
